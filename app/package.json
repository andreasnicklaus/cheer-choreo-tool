{
  "name": "choreo-tool",
  "version": "0.12.1",
  "private": true,
  "scripts": {
    "dev": "npm run icons && vite",
    "build": "npm run icons && npm run docs && vite build && npm run prerender && npm run sitemap",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "icons": "vue-asset-generate -a ./public/Icon.png -b #FFFFFF",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "docs": "jsdoc -c jsdoc.json",
    "docs:watch": "concurrently --kill-others \"live-server ./public/docs\" \"nodemon --exec npm run docs\"",
    "docs:update": "nodemon --exec npm run docs",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e:pretest": "tsc --noEmit",
    "test:e2e": "npm run test:e2e:pretest && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@logtail/browser": "^0.5.6",
    "@unhead/vue": "^2.1.4",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.5",
    "axios-cache-interceptor": "^1.11.4",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.43.7",
    "clean-jsdoc-theme": "^4.3.0",
    "gsap": "^3.14.2",
    "javascript-time-ago": "^2.6.2",
    "js-cookie": "^3.0.5",
    "jsdoc": "^4.0.5",
    "jsdoc-vuejs": "^4.0.0",
    "jspdf": "^2.5.2",
    "register-service-worker": "^1.7.2",
    "unleash-proxy-client": "^3.7.8",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-matomo": "^4.2.0",
    "vue-pwa-asset-generator": "^1.7.3",
    "vue-router": "^5.0.3",
    "vue3-country-flag-icon": "^0.1.2",
    "vue3-html2pdf": "^1.0.2",
    "vue3-markdown-it": "^1.0.10",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/compiler-sfc": "^3.5.29",
    "@vue/tsconfig": "^0.8.1",
    "html-minifier-terser": "^7.2.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "puppeteer": "^20.9.0",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "sitemap-generator": "^1.2.0",
    "typescript": "~5.9.3",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "nodemonConfig": {
    "ignore": [
      "./public/docs"
    ],
    "ext": "vue,js,md"
  }
}
