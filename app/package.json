{
  "name": "choreo-tool",
  "version": "0.13.1",
  "private": true,
  "scripts": {
    "dev": "npm run icons && vite",
    "build": "npm run icons && npm run docs && vite build && npm run prerender && npm run sitemap",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "icons": "vue-asset-generate -a ./public/Icon.png -b #FFFFFF",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "docs": "jsdoc -c jsdoc.json",
    "docs:watch": "concurrently --kill-others \"live-server ./public/docs\" \"nodemon --exec npm run docs\"",
    "docs:update": "nodemon --exec npm run docs",
    "test": "npm run test:unit && npm run test:e2e",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "test:pretest": "npm run lint && tsc --noEmit",
    "test:e2e": "npm run test:pretest && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "npm run test:pretest &&vitest run",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@logtail/browser": "^0.5.8",
    "@unhead/vue": "^3.0.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.0",
    "axios-cache-interceptor": "^1.12.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.45.0",
    "gsap": "^3.15.0",
    "javascript-time-ago": "^2.6.4",
    "js-cookie": "^3.0.5",
    "register-service-worker": "^1.7.2",
    "unleash-proxy-client": "^3.8.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-matomo": "^4.2.0",
    "vue-router": "^5.0.6",
    "vue3-country-flag-icon": "^0.1.2",
    "vue3-html2pdf": "^1.1.2",
    "vue3-markdown-it": "^1.0.10",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@estruyf/github-actions-reporter": "^1.12.0",
    "@iconify-json/bi": "^1.2.7",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/compiler-sfc": "^3.5.34",
    "@vue/tsconfig": "^0.9.0",
    "clean-jsdoc-theme": "^4.3.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "html-minifier-terser": "^7.2.0",
    "jsdoc": "^4.0.5",
    "jsdoc-vuejs": "^4.0.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.3",
    "puppeteer": "^24.0.0",
    "sass": "^1.99.0",
    "sass-embedded": "^1.99.0",
    "serve": "^14.2.6",
    "sitemap-generator": "^8.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.1.0",
    "vite": "^7.3.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "vue-pwa-asset-generator": "^1.7.3",
    "vue-tsc": "^3.2.8"
  },
  "nodemonConfig": {
    "ignore": [
      "./public/docs"
    ],
    "ext": "vue,js,md"
  },
  "overrides": {
    "node-sass": "npm:sass@^1.98.0",
    "jspdf": "^4.2.1"
  }
}
