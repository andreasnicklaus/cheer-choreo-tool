<!DOCTYPE html>
<html lang="<%= locals.locale? locale : 'en' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= t('mail.newContactMessage.new-message') %></title>
  </head>
  <body>
    <h1 style="text-align: center">
      📨 <%= t('mail.newContactMessage.new-contact-message') %> 📨
    </h1>

    <p><%= t('mail.newContactMessage.hello') %></p>

    <p><%= t('mail.newContactMessage.info-text-1') %></p>
    <p>Name: <b><%= name %></b><br/>
    E-Mail: <b><a href="mailto:<%= email %>" ><%= email %></a></b><br/>
    Category: <b><%= category %></b><br/>
    Subject: <b><%= subject %></b><br/>
    Message: <pre><%= message %></pre><br/>
    Locale: <b><%= messageLocale %></b></p>

    <p><%= t('mail.newContactMessage.info-text-2') %></p>

    
    <% if (user) { %>
      <p><%= t('mail.newContactMessage.logged-in') %></p>
      <p>Name: <b><%= user.username %></b></p>
      <p>E-Mail: <b><a href="mailto:<%= user.email %>" ><%= user.email %></a></b></p>
    <% } else { %>
      <p><%= t('mail.newContactMessage.not-logged-in') %></p>
    <% } %>

    <p>
      <%- t('mail.general.sender') %><!-- njsscan-ignore: ejs_ect_template -->
    </p>

    <p>
      <small>
        <%- t('mail.general.auto-email-info') %><!-- njsscan-ignore: ejs_ect_template -->
      </small>
    </p>

    <hr />

    <img
      src="cid:choreo-planer-icon"
      alt="Choreo Planer Icon"
      width="100"
      height="100"
    />

    <p>
      <a href="https://www.choreo-planer.de">www.choreo-planer.de</a><br />
      <a href="mailto:info@choreo-planer.de">info@choreo-planer.de</a>
    </p>
  </body>
</html>
