meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "salachglam",
    "password": "salachglam"
  }
}

script:post-response {
  if (res.getStatus() >= 200 && res.getStatus() < 300) {
    const token = res.getBody();
    if (token) {
      bru.setVar("token", token);
    }
  }
}
