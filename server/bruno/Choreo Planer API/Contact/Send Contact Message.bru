meta {
  name: Send Contact Message
  method: POST
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/contact/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Salach Glam",
    "email": "noreply@choreo-planer.de",
    "subject": "Fragen zur Choreo",
    "message": "Ich habe eine Frage zur RM 2023 Choreografie.",
    "category": "support"
  }
}
