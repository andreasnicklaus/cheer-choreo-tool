meta {
  name: Send Notification
  method: POST
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/admin/notifications/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "message": "Hello users!",
    "title": "Announcement",
    "targetUsers": ["user-id"],
    "notifyViaEmail": "false",
    "sendToAllUsers": "false"
  }
}
